#include <iostream>
using namespace std;
struct node
{
    int data;
    node *next;
};
int main()
{
    node *head = NULL, *temp, *newnode;
    int ch, n, i;
    char x;
    do
    {
        cout<<"\n1. Create Linked List";
        cout<<"\n2. Insert at Beginning";
        cout<<"\n3. Insert at End";
        cout<<"\n4. Display";
        cout<<"\nEnter your choice: ";
        cin>>ch;
        switch(ch)
        {
            case 1: 
                cout<<"Enter number of nodes: ";
                cin>>n;
                for(i=1;i<=n;i++)
                {
                    newnode = new node;
                    cout<<"Enter data: ";
                    cin>>newnode->data;
                    newnode->next = NULL;
                    if(head == NULL)
                    {
                        head = newnode;
                        temp = head;
                    }
                    else
                    {
                        temp->next = newnode;
                        temp = newnode;
                    }
                }
                break;
            case 2:
                newnode = new node;
                cout<<"Enter value: ";
                cin>>newnode->data;
                newnode->next = head;
                head = newnode;
                break;
            case 3:
                newnode = new node;
                cout<<"Enter value: ";
                cin>>newnode->data;
                newnode->next = NULL;
                if(head == NULL)
                {
                    head = newnode;
                }
                else
                {
                    temp = head;
                    while(temp->next != NULL)
                    {
                        temp = temp->next;
                    }
                    temp->next = newnode;
                }
                break;
            case 4:
                if(head == NULL)
                {
                    cout<<"List is empty";
                }
                else
                {
                    temp = head;
                    cout<<"Linked List: ";
                    while(temp != NULL)
                    {
                        cout<<temp->data<<" -> ";
                        temp = temp->next;
                    }
                    cout<<"NULL";
                }
                break;
        }
        cout<<"Do you want to continue";
        cin>>x;
    } 
    while(x=='y' || x=='Y');
    return 0;
}
