#include <iostream>
#include <queue>
using namespace std;
struct node {
    int data;
    node* next;
};

int main() {
    node *head = NULL, *temp;
    queue<int> q;
    int choice, value, n;
    char x;

    do {
        cout << "1. Create List\n";
        cout << "2. Display List\n";
        cout << "3. Reverse using Queue\n";
        cout << "Enter your choice: ";
        cin >> choice;

        switch(choice) {

            case 1: 
            {
                cout << "Enter number of elements: ";
                cin >> n;

                for(int i = 0; i < n; i++) {
                    node* newNode = new node;
                    cout << "Enter value: ";
                    cin >> value;

                    newNode->data = value;
                    newNode->next = NULL;

                    if(head == NULL) {
                        head = newNode;
                    } else {
                        temp = head;
                        while(temp->next != NULL)
                            temp = temp->next;
                        temp->next = newNode;
                    }
                }
                cout << "Linked List Created\n";
                break;
            }

            case 2:
            {
                if(head == NULL) {
                    cout << "List is Empty\n";
                } else {
                    temp = head;
                    cout << "Linked List:\n";
                    while(temp != NULL) {
                        cout << temp->data << " ";
                        temp = temp->next;
                    }
                    cout << endl;
                }
                break;
            }

            case 3: 
            {
                if(head == NULL) {
                    cout << "List is Empty\n";
                } else {
                    temp = head;

                    // Step 1: Push elements into queue
                    while(temp != NULL) {
                        q.push(temp->data);
                        temp = temp->next;
                    }
                    int arr[100], i = 0;
                    while(!q.empty()) {
                        arr[i++] = q.front();
                        q.pop();
                    }

                    // Step 3: Assign in reverse order
                    temp = head;
                    for(int j = i - 1; j >= 0; j--) {
                        temp->data = arr[j];
                        temp = temp->next;
                    }

                    cout << "List Reversed using Queue\n";
                }
                break;
            }

        cout << "Do you want to continue (y/n): ";
        cin >> x;

    } while(x == 'y' || x == 'Y');

    return 0;
}
