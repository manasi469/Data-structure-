#include <iostream>
using namespace std;

#define MAX 5

int main() {
    int stack[MAX];
    int TOP = -1;
    int choice, value;
    char x;

    do {
        cout << "1. Push\n";
        cout << "2. Pop\n";
        cout << "3. Peek\n";
        cout << "4. isEmpty\n";
        cout << "5. isFull\n";
        cout << "6. Display\n";
        cout << "Enter your choice: ";
        cin >> choice;

        switch(choice) {

            case 1: 
                if (TOP == MAX - 1) {
                    cout << "Stack Overflow\n";
                } else {
                    cout << "Enter value: ";
                    cin >> value;
                    TOP++;
                    stack[TOP] = value;
                    cout << value << " pushed into stack\n";
                }
                break;

            case 2: 
                if (TOP == -1) {
                    cout << "Stack Underflow\n";
                } else {
                    cout << "Popped element: " << stack[TOP] << endl;
                    TOP--;
                }
                break;

            case 3: 
                if (TOP == -1) {
                    cout << "Stack is Empty\n";
                } else {
                    cout << "Top element: " << stack[TOP] << endl;
                }
                break;

            case 4: 
                if (TOP == -1)
                    cout << "Stack is Empty\n";
                else
                    cout << "Stack is Not Empty\n";
                break;

            case 5: 
                if (TOP == MAX - 1)
                    cout << "Stack is Full\n";
                else
                    cout << "Stack is Not Full\n";
                break;

            case 6: 
                if (TOP == -1) {
                    cout << "Stack is Empty\n";
                } else {
                    cout << "Stack elements:\n";
                    for (int i = TOP; i >= 0; i--) {
                        cout << stack[i] << endl;
                    }
                }
                break;
        }

        cout << "Do you want to continue: ";
        cin >> x;

    } while (x == 'y' || x == 'Y');

    return 0;
}
